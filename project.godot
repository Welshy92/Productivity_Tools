; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Productivity Tools"
config/description="A suite of productivity tools that is in a small window that can sit in the corner of your screen, out of the way.

Created by Jacob of PhoenixDragon Games.
Visit http://www.phoenixdragongames.com to see more of my work."
config/version="3.0"
run/main_scene="uid://druk6ch8sy8cj"
config/features=PackedStringArray("4.5", "GL Compatibility")
run/low_processor_mode=true
boot_splash/bg_color=Color(0, 0, 0, 0)
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false
config/icon="res://icon.svg"

[autoload]

NoteSaveAndLoad="*res://Scripts/note_save_and_load.gd"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=1
window/size/viewport_height=1
window/size/initial_position_type=0
window/size/initial_position=Vector2i(9000, 9000)
window/size/initial_screen=6
window/size/resizable=false
window/size/borderless=true
window/size/always_on_top=true
window/size/transparent=true
window/size/window_width_override=1
window/size/window_height_override=1
window/energy_saving/keep_screen_on=false
window/subwindows/embed_subwindows=false
window/per_pixel_transparency/allowed=true

[input]

left_click={
"deadzone": 0.2,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}

[rendering]

viewport/transparent_background=true
